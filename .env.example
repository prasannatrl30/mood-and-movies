# Copy this file to .env and fill in your keys (.env is gitignored).

# Writes the recommendation text
ANTHROPIC_API_KEY=your_anthropic_key_here
# Posters, ratings, streaming providers
TMDB_API_KEY=your_tmdb_key_here

# ── Instagram (see INSTAGRAM-SETUP.md) ──
# Long-lived Instagram access token with content-publish permission.
IG_ACCESS_TOKEN=
# Optional — auto-resolved from the token if blank.
IG_USER_ID=
# Handle shown on the card footer.
IG_HANDLE=@moodandmovies_
# Only needed for local publishing (CI sets this automatically):
# the public URL where posts/latest.jpg is reachable.
CARD_IMAGE_URL=
